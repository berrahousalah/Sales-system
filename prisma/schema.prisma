// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// PRODUCT CATALOG
// ─────────────────────────────────────────────

model Product {
  id           String   @id @default(uuid())
  name         String
  stockBalance Int      @default(0)
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  batches            Batch[]
  importInvoiceLines ImportInvoiceLine[]
}

// ─────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────

model Supplier {
  id        String   @id @default(uuid())
  name      String
  totalDebt Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches        Batch[]
  importInvoices ImportInvoice[]
  supplierReturn SupplierReturn[]
}

// ─────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(uuid())
  name      String
  totalDebt Decimal  @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salesInvoices SalesInvoice[]
}

// ─────────────────────────────────────────────
// IMPORT INVOICES
// ─────────────────────────────────────────────

model ImportInvoice {
  id                 String   @id @default(uuid())
  invoiceNumber      String   @unique
  supplierId         String
  invoiceDate        DateTime @default(now())
  transportationCost Decimal  @default(0)
  totalAmount        Decimal  @default(0)
  amountPaid         Decimal  @default(0)
  debtBalance        Decimal  @default(0)
  status             String   @default("UNPAID") // UNPAID | PARTIAL | PAID
  isHeaderLocked     Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lines    ImportInvoiceLine[]
}

model ImportInvoiceLine {
  id              String  @id @default(uuid())
  importInvoiceId String
  productId       String
  quantity        Int
  quantitySold    Int     @default(0)
  purchasePrice   Decimal
  retailPrice     Decimal
  isSerialised    Boolean @default(false)
  isLocked        Boolean @default(false) // true when quantitySold > 0

  importInvoice  ImportInvoice    @relation(fields: [importInvoiceId], references: [id], onDelete: Restrict)
  product        Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  serialNumbers  SerialNumber[]
  batch          Batch?
  supplierReturn SupplierReturn[]
}

model SerialNumber {
  id                  String  @id @default(uuid())
  serial              String  @unique
  importInvoiceLineId String
  isSold              Boolean @default(false)
  isReturned          Boolean @default(false)
  isAdjusted          Boolean @default(false)
  adjustmentReason    String?

  importInvoiceLine ImportInvoiceLine @relation(fields: [importInvoiceLineId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// INVENTORY BATCHES (created when invoice header is locked/saved)
// ─────────────────────────────────────────────

model Batch {
  id                  String   @id @default(uuid())
  productId           String
  supplierId          String
  importInvoiceLineId String   @unique
  quantityReceived    Int
  quantityRemaining   Int
  purchasePrice       Decimal 
  retailPrice         Decimal 
  entryDate           DateTime @default(now())

  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplier          Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  importInvoiceLine ImportInvoiceLine @relation(fields: [importInvoiceLineId], references: [id], onDelete: Restrict)

  salesLines           SalesInvoiceLine[]
  quickSales           QuickSale[]
  inventoryAdjustments InventoryAdjustment[]
}

// ─────────────────────────────────────────────
// SUPPLIER RETURNS
// ─────────────────────────────────────────────

model SupplierReturn {
  id                  String   @id @default(uuid())
  supplierId          String
  importInvoiceLineId String
  quantityReturned    Int
  returnedSerials     String // empty if non-serialised
  costDeducted        Decimal 
  createdAt           DateTime @default(now())

  supplier          Supplier          @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  importInvoiceLine ImportInvoiceLine @relation(fields: [importInvoiceLineId], references: [id], onDelete: Restrict)
}

// ─────────────────────────────────────────────
// SALES INVOICES (formal — customer debt ledger)
// ─────────────────────────────────────────────

model SalesInvoice {
  id             String   @id @default(uuid())
  invoiceNumber  String   @unique
  customerId     String
  invoiceDate    DateTime @default(now())
  deliveryCost   Decimal  @default(0)
  totalAmount    Decimal  @default(0)
  amountPaid     Decimal  @default(0)
  debtBalance    Decimal  @default(0)
  status         String   @default("UNPAID") // UNPAID | PARTIAL | PAID
  isHeaderLocked Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lines    SalesInvoiceLine[]
}

model SalesInvoiceLine {
  id                    String   @id @default(uuid())
  salesInvoiceId        String
  batchId               String
  quantity              Int
  sellingPrice          Decimal  // editable by merchant; retail price is default
  // COGS reference — stored at time of sale for profit tracking; never exposed to UI batch picker
  purchasePriceSnapshot Decimal 
  soldSerials           String // serial numbers sold (empty for non-serialised)

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)
  batch        Batch        @relation(fields: [batchId], references: [id], onDelete: Restrict)
}

// ─────────────────────────────────────────────
// QUICK SALES (direct POS — no customer, cash only)
// ─────────────────────────────────────────────

model QuickSale {
  id                    String   @id @default(uuid())
  batchId               String
  quantity              Int
  sellingPrice          Decimal 
  totalAmount           Decimal 
  purchasePriceSnapshot Decimal 
  soldSerials           String
  saleDate              DateTime @default(now())
  isReturned            Boolean  @default(false)

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Restrict)
}

// ---------------------------------------------
// INVENTORY ADJUSTMENTS (Phase 6)
// ---------------------------------------------

model InventoryAdjustment {
  id                    String   @id @default(uuid())
  batchId               String
  quantity              Int
  reason                String // DAMAGED | LOST | INTERNAL_USE | AUDIT_CORRECTION
  purchasePriceSnapshot Decimal 
  financialLoss         Decimal 
  adjustedSerials       String
  createdAt             DateTime @default(now())

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Restrict)
}

// ---------------------------------------------
// FINANCIAL CLOSING & REPORTING (Phase 7)
// ---------------------------------------------

model MonthlyFinancialReport {
  id                     String   @id @default(uuid())
  closingMonthId         String   @unique // e.g. '2026-06'
  totalRevenue           Decimal 
  totalCOGS              Decimal 
  totalLogisticsExpenses Decimal 
  totalAdjustmentLosses  Decimal 
  finalNetProfit         Decimal 
  closedAt               DateTime @default(now())
}

model TransactionLedger {
  id                  String   @id @default(uuid())
  type                String // 'RETROACTIVE_RETURN_SALES', 'RETROACTIVE_RETURN_QUICK', 'ADJUSTMENT_POST_CLOSE'
  referenceId         String // Original invoice/sale ID
  deltaRevenue        Decimal  @default(0)
  deltaCOGS           Decimal  @default(0)
  deltaLogistics      Decimal  @default(0)
  deltaAdjustmentLoss Decimal  @default(0)
  description         String?
  createdAt           DateTime @default(now())
}
